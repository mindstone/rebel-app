{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@rebel/shared": ["./packages/shared/src"],
      "@rebel/shared/*": ["./packages/shared/src/*"],
      "@rebel/cloud-client": ["./cloud-client/src"],
      "@rebel/cloud-client/*": ["./cloud-client/src/*"]
    }
  },
  "include": [
    "src/renderer/**/*",
    "src/shared/**/*",
    "src/core/safetyPromptTypes.ts",
    "src/core/heroChoiceTypes.ts",
    "src/core/dailySparkTypes.ts",
    "src/core/mcpInternalEnvKeys.ts",
    "src/core/rebelCore/superMcpContract.ts",
    "src/core/skillQualityScore.ts",
    "src/core/utils/portablePath.ts",
    "src/core/utils/readLines.ts",
    "src/core/utils/throughputEstimator.ts",
    "src/core/utils/finishLine.ts",
    "src/core/services/identity/userIdentityValidation.ts",
    "src/core/services/spacePathMatcher.ts",
    "src/core/services/spaceOrganisationHeuristics.ts",
    "src/core/services/communityEventsTypes.ts",
    "src/core/services/communityVideoRecsTypes.ts",
    "src/core/services/cloudErrorMapper.ts",
    "src/core/services/cloud/vmTierCatalog.ts",
    "src/core/services/cloud/tierSuggestionEngine.ts",
    "src/core/services/cloud/cloudErrorCategory.ts",
    "src/core/services/cloud/cloudConnectionReconcilerTypes.ts",
    "src/core/services/cloudUpdateProgress.ts",
    "src/core/services/oauthTransport.ts",
    "src/core/services/spaceGoalsTypes.ts",
    "src/core/services/meetingTypeClassifier.ts",
    "src/core/services/calendarTimeUtils.ts",
    "src/core/services/prepAlignmentTypes.ts",
    "src/core/services/goalAlignmentService.ts",
    "src/core/services/diagnostics/diagnosticEventDisplay.ts",
    "src/core/services/diagnostics/manifest.ts",
    "src/core/services/health/types.ts",
    "src/core/services/agentTurnReducer/**/*",
    "src/core/services/conversationState/**/*",
    "src/core/services/sessionIngestGuard.ts",
    "src/core/rebelCore/parallelSubagentsStatus.ts",
    "src/core/rebelCore/roleAssignment.ts",
    "src/core/rebelCore/settingsAccessorsPure.ts",
    "src/core/services/pendingRetryStore.ts",
    "src/core/services/cloud/providers/volumeDefaults.ts",
    "src/core/services/localInference/ollamaTypes.ts",
    "src/core/services/localInference/modelCatalog.ts",
    "src/core/rebelCore/modelRoleResolver.ts",
    "src/core/goalTypes.ts",
    "src/core/constants.ts",
    "src/core/errorReporter.ts",
    "src/core/logBuffer.ts",
    "src/core/logger.ts",
    "src/core/platform.ts",
    "src/core/tracking.ts",
    "src/core/sentry/*.ts",
    "src/core/utils/dataPaths.ts",
    "src/core/services/costLedgerService.ts",
    "src/core/services/diagnosticEventsLedger.ts",
    "src/core/services/nativeLivenessSnapshotSchema.ts",
    "src/core/types/contentResolutionReason.ts",
    "src/core/navigation/**/*",
    "src/core/appBridge/shared/**/*",
    "src/preload/**/*",
    "packages/shared/src/**/*",
    "scripts/import-rebel-oss-catalog-entry.ts",
    "scripts/lib/**/*.ts",
    "scripts/promote-preflight.ts",
    "scripts/promote-preflight-facts.ts",
    "scripts/release-to-production.ts",
    "scripts/check-knip-health.ts",
    "scripts/check-eslint-new-warnings.ts",
    "cloud-client/src/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "src/renderer/**/*.stories.tsx",
    "src/shared/**/__tests__/**",
    "packages/shared/src/**/__tests__/**",
    "cloud-client/src/**/__tests__/**/*.test.ts",
    "cloud-client/src/**/__tests__/**/*.test.tsx",
    "cloud-client/src/**/__tests__/**/*.spec.ts"
  ]
}
