    "dev": "node -e \"const d=new Date();const p=n=>String(n).padStart(2,'0');console.log('\\n\\x1b[1;36m========================================');console.log('  DEV STARTED: '+String(d.getFullYear()).slice(2)+p(d.getMonth()+1)+p(d.getDate())+'_'+p(d.getHours())+p(d.getMinutes()));console.log('========================================\\x1b[0m\\n')\" && node scripts/run-dev-with-cdp-default.mjs electron-forge start",
    "dev:local": "cross-env REBEL_API_URL=http://localhost:8080 node scripts/run-dev-with-cdp-default.mjs electron-forge start",
    "dev:s101": "cross-env REBEL_API_URL=https://rebel.s101.mindstone.dev node scripts/run-dev-with-cdp-default.mjs electron-forge start",
    "dev:stop": "node scripts/stop-dev.mjs",
    "dev:perf": "cross-env VITE_PERFORMANCE=true REBEL_PERF_MODE=1 CAPTURE_MEMORY_UPDATES=1 node scripts/run-dev-with-cdp-default.mjs electron-forge start",
    "dev:perf:validate": "cross-env VITE_PERFORMANCE=true REBEL_PERF_MODE=1 CAPTURE_MEMORY_UPDATES=1 REBEL_INDEXER_PAUSE_ON_BLUR=1 node scripts/run-dev-with-cdp-default.mjs electron-forge start",
