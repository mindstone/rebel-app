# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Logs
logs/
*.log
# Keep CI investigation classifier fixtures versioned.
!scripts/__tests__/fixtures/ci-investigate/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# Node/Electron dependencies
node_modules/
jspm_packages/

# Build artifacts
dist/
out/
build/
release/
*.asar
*.asar.unpacked/
# Allow committed app icons and config inside build/
!build/icon.icns
!build/icon.ico
!build/icon.png
!build/app-icon-source.png
!build/entitlements.mac.plist
!build/*.nsh

# TypeScript
*.tsbuildinfo
*.tsbuildinfo.*

# Tooling caches
.lycheecache
.vite/
.cache/
.eslintcache
.stylelintcache

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Environment files
.env
.env.*
!.env.example
!.env.oss-test.example
!.env.test.example
.claude/settings.local.json
# .claude/settings.json is tracked (shared team hooks — Claude Code transcript
# export). Personal/machine-specific overrides go in .claude/settings.local.json.
.claude/scheduled_tasks.lock
# Harness/built-in worktrees (Agent isolation:worktree, EnterWorktree) land here.
# Prefer init-worktree.sh (sibling worktrees outside the repo); never commit these.
.claude/worktrees/

# Editor directories and files
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~
Thumbs.db
tmp/
temp/
.local/

# Session replay fixtures (extracted from local session store, contain personal data)
src/core/rebelCore/__tests__/sessionReplay/fixtures/

# Local development utilities (not in CI)
gjdutils/

# Electron specific
*.dmg
*.app
*.exe
*.msi
*.deb
*.rpm
*.AppImage

# Generated runtime config
config/app-config.json

# Testing
.jest/

# Playwright test artifacts
test-results/
# Playwright JSON report (config 'json' reporter default output at repo root; CI
# uploads it as an artifact, local runs shouldn't litter the tree).
/e2e-results.json
/e2e-perf-results.json
# Same JSON reporter, named via PLAYWRIGHT_JSON_OUTPUT_NAME by the chronic
# staleness gate (test:e2e:chronic); release.yml reads it from repo root.
/chronic-staleness-results.json

# Eval result outputs (written to Google Drive when available, repo fallback here)
# Local eval run artifacts (smokes, comparisons, spikes; never commit)
evals/runs/
# Ignore everything under evals/results/ by default…
evals/results/*
# …also ignore the legacy/alternate top-level eval-results/ output path some harnesses use.
eval-results/
# …but keep checked-in baselines for regression detection (see TESTING_EVALS_*.md)
!evals/results/narration-baseline.json
!evals/results/connector-build/
evals/results/connector-build/*
!evals/results/connector-build/baseline-*.json
!evals/results/connector-build/baselines/
evals/results/connector-build/baselines/*
!evals/results/connector-build/baselines/v*-pre-refactor/
!evals/results/connector-build/baselines/v*-pre-refactor/*.json
!evals/results/connector-build/baselines/v*-pre-refactor/*.md
# Long-form trend snapshots are committable summaries written by the
# `--summary-trend` flag on the knowledge-work harness — small JSON + CSV
# files designed to live in git for over-time tracking. See
# `evals/results/long-form-trend/README.md` and `evals/trend-summary.ts`.
!evals/results/long-form-trend/
!evals/results/long-form-trend/**
docs/evals/

# Eval config keys (legacy files — kept gitignored as a safety net even though
# the current flow reads keys from app-settings.json at runtime; setupEnvEvals
# auto-deletes any stragglers it finds.)
evals/.env.evals
evals/.config.json
evals/configs/.local/**
!evals/configs/.local/.gitkeep
evals/results/**/.judge-inputs/
.judge-inputs/

# Eval built output (generated by build.mjs / build-verify.mjs / build-semantic-retrieval.mjs)
evals/.built.mjs
evals/.built.mjs.map
evals/.built-verify.mjs
evals/.built-verify.mjs.map
evals/.built-semantic-retrieval.mjs
evals/.built-semantic-retrieval.mjs.map

# Workspace eval snapshots (contain workspace content — never commit)
evals/.workspace-snapshot/

*.code-workspace

# Generated runtime bundles
resources/node-bundle/
resources/git-bundle/
resources/mcp-generated/

# Local STT - ignore downloaded models, keep binaries and docs
resources/local-stt/*.downloading
resources/local-stt/models/

.cursor/cli.json


# Factory AI generated files
.factory/reviews/
.factory/conversations/.exported/
.factory/conversations/.last_backup_check
# Droid conversations (canonical location: Google Drive > Product > droid-conversations)
docs/conversations/

# Droid pathologist reports (canonical location: Google Drive > Product > droid-pathologist-reports)
droid-pathologist-reports/

# Code health tool outputs (HTML reports)
docs/reports/code-health/*.html

# CASA security scan outputs
casa/
.wrangler/

# Cursor MCP credentials (do not commit)
.cursor/mcp.json

# Local keys (do not commit)
.env.local

# Mobile app
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/ios/
mobile/android/

# Python
__pycache__/

# Generated analysis artifacts
.impact-map.json
mirror-output-validator.json
stats-*.html
.rebel/
.monitor-state/
/docs/project/ux_testing/reports/screenshots

# Postmortem recommendations — generated build artifact (commit only _recommendations_overrides.yaml)
docs-private/postmortems/_index_recommendations.generated.yaml
docs-private/postmortems/_recs_hotlist.generated.json

# Perf baseline captures — keep PROCEDURE.md, REPORT-*.md, and small baseline-*.json
# but never commit raw renderer CPU profiles (10s of MB each; locally regenerable)
tests/perf-baselines/**/phaseF-*-cpu-profile-*.json
tests/perf-baselines/**/*.cpuprofile

# Eval-runner scratch — orphan PID/log trackers and killed-run recovery dumps
# (large payloads with full prompts/workspace paths; never durable across runs).
*.pid
*.logpath
.minimax-killed-run-recovery/
.eval-killed-run-recovery/
