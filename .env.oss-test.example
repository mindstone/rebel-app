# .env.oss-test.example — credentials for scripts/test-oss-connectors.ts
# Generated from resources/connector-catalog.json. Regenerate with:
#   npx tsx scripts/test-oss-connectors.ts --generate-env-example
#
# Copy to .env.oss-test (gitignored) and fill in real values. Then run:
#   npm run test:oss-connectors -- --env-file .env.oss-test
#
# Naming convention: OSS_TEST_<connector_id_upper_snake>__<field_id_upper_snake>
# The runner ALSO honours the legacy envVar (e.g., FATHOM_API_KEY) as fallback.
# Normal OSS app setup for Google, Slack, HubSpot, and Microsoft is in-app;
# this file exercises the connector-smoke-test/env-override path.

# bundled-fathom — Fathom
# Fathom API Key — legacy envVar: FATHOM_API_KEY
OSS_TEST_BUNDLED_FATHOM__API_KEY=

# bundled-google-analytics — Google Analytics
# Credentials file (absolute path) — legacy envVar: GOOGLE_APPLICATION_CREDENTIALS
OSS_TEST_BUNDLED_GOOGLE_ANALYTICS__CREDENTIALS_PATH=
# Default GA4 property ID (optional) (optional) — legacy envVar: GA4_PROPERTY_ID
OSS_TEST_BUNDLED_GOOGLE_ANALYTICS__PROPERTY_ID=

# bundled-icloud-mail — iCloud Mail
# App-Specific Password — legacy envVar: EMAIL_IMAP_PASSWORD
OSS_TEST_BUNDLED_ICLOUD_MAIL__PASSWORD=

# bundled-yahoo-mail — Yahoo Mail
# App Password — legacy envVar: EMAIL_IMAP_PASSWORD
OSS_TEST_BUNDLED_YAHOO_MAIL__PASSWORD=

# bundled-custom-email — Custom Email (IMAP/SMTP)
# IMAP Server — legacy envVar: EMAIL_IMAP_IMAP_HOST
OSS_TEST_BUNDLED_CUSTOM_EMAIL__IMAP_HOST=
# IMAP Port — legacy envVar: EMAIL_IMAP_IMAP_PORT
OSS_TEST_BUNDLED_CUSTOM_EMAIL__IMAP_PORT=
# SMTP Server — legacy envVar: EMAIL_IMAP_SMTP_HOST
OSS_TEST_BUNDLED_CUSTOM_EMAIL__SMTP_HOST=
# SMTP Port — legacy envVar: EMAIL_IMAP_SMTP_PORT
OSS_TEST_BUNDLED_CUSTOM_EMAIL__SMTP_PORT=
# Password — legacy envVar: EMAIL_IMAP_PASSWORD
OSS_TEST_BUNDLED_CUSTOM_EMAIL__PASSWORD=

# bundled-pandadoc — PandaDoc
# PandaDoc API Key — legacy envVar: PANDADOC_API_KEY
OSS_TEST_BUNDLED_PANDADOC__API_KEY=

# bundled-mixmax — Mixmax
# Mixmax API Token — legacy envVar: MIXMAX_API_TOKEN
OSS_TEST_BUNDLED_MIXMAX__API_KEY=

# bundled-zendesk — Zendesk

# bundled-freshdesk — Freshdesk

# bundled-hubspot — HubSpot: OAuth or host-only, no env credentials.

# bundled-salesforce — Salesforce

# bundled-outreach — Outreach

# bundled-gamma — Gamma
# Gamma API Key — legacy envVar: GAMMA_API_KEY
OSS_TEST_BUNDLED_GAMMA__API_KEY=

# bundled-napkin — Napkin AI
# Napkin API Key — legacy envVar: NAPKIN_API_KEY
OSS_TEST_BUNDLED_NAPKIN__API_KEY=

# bundled-elevenlabs — ElevenLabs
# ElevenLabs API Key — legacy envVar: ELEVENLABS_API_KEY
OSS_TEST_BUNDLED_ELEVENLABS__API_KEY=

# bundled-retell-ai — Retell AI
# Retell AI API Key — legacy envVar: RETELL_API_KEY
OSS_TEST_BUNDLED_RETELL_AI__API_KEY=

# bundled-kling — Kling AI
# Access Key — legacy envVar: KLING_ACCESS_KEY
OSS_TEST_BUNDLED_KLING__ACCESS_KEY=
# Secret Key — legacy envVar: KLING_SECRET_KEY
OSS_TEST_BUNDLED_KLING__SECRET_KEY=

# bundled-runway — Runway ML
# Runway API Key — legacy envVar: RUNWAYML_API_SECRET
OSS_TEST_BUNDLED_RUNWAY__API_KEY=

# bundled-nano-banana — Nano Banana
# Gemini API Key — legacy envVar: GEMINI_API_KEY
OSS_TEST_BUNDLED_NANO_BANANA__API_KEY=

# bundled-browser-automation — Browser Automation
# Show the browser window (optional) — legacy envVar: AGENT_BROWSER_SHOW_WINDOW
OSS_TEST_BUNDLED_BROWSER_AUTOMATION__SHOW_BROWSER_WINDOW=

# bundled-office — Microsoft Office: OAuth or host-only, no env credentials.

# bundled-humaans — Humaans
# Humaans API Token — legacy envVar: HUMAANS_API_KEY
OSS_TEST_BUNDLED_HUMAANS__API_KEY=

# bundled-workday — Workday
# Workday Host — legacy envVar: WORKDAY_HOST
OSS_TEST_BUNDLED_WORKDAY__HOST=
# Tenant Name — legacy envVar: WORKDAY_TENANT
OSS_TEST_BUNDLED_WORKDAY__TENANT=
# Client ID — legacy envVar: WORKDAY_CLIENT_ID
OSS_TEST_BUNDLED_WORKDAY__CLIENT_ID=
# Client Secret — legacy envVar: WORKDAY_CLIENT_SECRET
OSS_TEST_BUNDLED_WORKDAY__CLIENT_SECRET=
# Refresh Token (optional) — legacy envVar: WORKDAY_REFRESH_TOKEN
OSS_TEST_BUNDLED_WORKDAY__REFRESH_TOKEN=

# bundled-quickbooks — QuickBooks Online
# Client ID — legacy envVar: QUICKBOOKS_CLIENT_ID
OSS_TEST_BUNDLED_QUICKBOOKS__CLIENT_ID=
# Client Secret — legacy envVar: QUICKBOOKS_CLIENT_SECRET
OSS_TEST_BUNDLED_QUICKBOOKS__CLIENT_SECRET=
# Refresh Token — legacy envVar: QUICKBOOKS_REFRESH_TOKEN
OSS_TEST_BUNDLED_QUICKBOOKS__REFRESH_TOKEN=
# Company ID (Realm ID) — legacy envVar: QUICKBOOKS_REALM_ID
OSS_TEST_BUNDLED_QUICKBOOKS__REALM_ID=
# Environment — legacy envVar: QUICKBOOKS_ENVIRONMENT
OSS_TEST_BUNDLED_QUICKBOOKS__ENVIRONMENT=

# bundled-servicenow — ServiceNow
# ServiceNow Instance — legacy envVar: SERVICENOW_INSTANCE
OSS_TEST_BUNDLED_SERVICENOW__INSTANCE=
# Username — legacy envVar: SERVICENOW_USERNAME
OSS_TEST_BUNDLED_SERVICENOW__USERNAME=
# Password — legacy envVar: SERVICENOW_PASSWORD
OSS_TEST_BUNDLED_SERVICENOW__PASSWORD=

# bundled-talentlms — TalentLMS
# TalentLMS Subdomain — legacy envVar: TALENTLMS_DOMAIN
OSS_TEST_BUNDLED_TALENTLMS__DOMAIN=
# TalentLMS API Key — legacy envVar: TALENTLMS_API_KEY
OSS_TEST_BUNDLED_TALENTLMS__API_KEY=

# bundled-apple-shortcuts — Apple Shortcuts: OAuth or host-only, no env credentials.

# bundled-replit-ssh — Replit SSH (manual entries, no setupFields — see scripts/lib/ossConnectorSmokeTests.ts).
# Required for the live probe; safe to leave unset (probe will fail with CONFIG_MISSING — use --skip bundled-replit-ssh in that case).
# Prerequisite: generate the key locally via `replit_setup_ssh` in the running Rebel app,
# then register ~/.ssh/rebel-replit.pub at https://replit.com/account#ssh-keys, then copy
# the SSH host/user from your Repl's "Connect manually" panel.
OSS_TEST_BUNDLED_REPLIT_SSH__HOST=
OSS_TEST_BUNDLED_REPLIT_SSH__USER=
