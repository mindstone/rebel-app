# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Maestro (ignore generated artifacts, keep flow YAML files)
.maestro/*
!.maestro/*.yaml

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Moonshine vendored files (downloaded at build time)
modules/moonshine-stt/ios/Frameworks/
modules/moonshine-stt/ios/MoonshineVoice/

# generated native folders
/ios
/android


