flowchart TB
    subgraph User[User]
        UA[Send Message]
    end

    subgraph Indexing[Indexing Flow - background]
        direction TB
        FW[[Chokidar Watcher]]
        Q[Async Queue<br/>1 file at a time<br/>50ms delays]
        CH[Chunking<br/>2000 char chunks<br/>200 char overlap]
        EMB1[Embedding Model<br/>all-MiniLM-L6-v2<br/>384 dimensions]
    end

    subgraph Search[Search Flow - per turn]
        direction TB
        QR[Query Refinement<br/>claude-haiku<br/>intent + terms]
        EMB2[Embedding Model<br/>all-MiniLM-L6-v2]
        VS[Vector Search<br/>cosine similarity<br/>threshold 0.55]
        FMT[Format Results<br/>Top 5 files<br/>Snippets + scores]
    end

    subgraph Storage[LanceDB]
        DB[(Vector Index<br/>path mtime chunks<br/>384-dim vectors)]
    end

    subgraph Agent[Agent Turn]
        CTX[Enhanced Prompt<br/>Workspace Files +<br/>User Request]
        LLM[Claude Sonnet]
    end

    FW -->|discover files| Q
    Q -->|process| CH
    CH -->|chunks| EMB1
    EMB1 -->|vectors| DB

    UA -->|query| QR
    QR -->|refined query| EMB2
    EMB2 -->|query vector| VS
    DB -->|similarity search| VS
    VS -->|top matches| FMT
    FMT -->|inject| CTX
    CTX --> LLM

    style User fill:#e1d5f7,stroke:#9673d3,stroke-width:2px
    style Indexing fill:#fff3cd,stroke:#d4a106,stroke-width:2px
    style Search fill:#d1ecf1,stroke:#0c5460,stroke-width:2px
    style Storage fill:#fff3cd,stroke:#d4a106,stroke-width:2px
    style Agent fill:#d4edda,stroke:#155724,stroke-width:2px
    
    style FW fill:#ffeeba,stroke:#d4a106
    style Q fill:#ffeeba,stroke:#d4a106
    style CH fill:#ffeeba,stroke:#d4a106
    style EMB1 fill:#bee5eb,stroke:#0c5460
    style EMB2 fill:#bee5eb,stroke:#0c5460
    style QR fill:#c3e6cb,stroke:#155724
    style VS fill:#bee5eb,stroke:#0c5460
    style FMT fill:#bee5eb,stroke:#0c5460
    style DB fill:#ffc107,stroke:#d4a106,stroke-width:2px
    style CTX fill:#c3e6cb,stroke:#155724
    style LLM fill:#c3e6cb,stroke:#155724
    style UA fill:#d8bfd8,stroke:#9673d3
