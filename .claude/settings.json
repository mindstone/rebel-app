{
  "model": "opus",
  "effortLevel": "high",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(./mirror/patches/**)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/coding-agent-instructions/hooks/export_transcript.py --claude-hook",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/coding-agent-instructions/hooks/export_transcript.py --claude-backup",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
