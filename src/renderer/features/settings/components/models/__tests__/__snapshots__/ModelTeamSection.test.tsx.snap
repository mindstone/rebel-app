exports[`ModelTeamSection > matches snapshot when managed allow-list is unavailable and membership stays editable 1`] = `"<section class="_section_20c7dc" data-section="modelTeam" data-testid="settings-model-team-section"><div class="_header_20c7dc"><div class="_titleBlock_20c7dc"><h2 class="_title_20c7dc" data-section-focus-target="true">Optional model team</h2><p class="_description_20c7dc">Add other models for Council discussions or Smart picking on routine steps. They cost whatever they cost.</p></div><label class="_masterToggle_20c7dc" for="model-team-smart-picking-toggle"><span>Smart model picking</span><input class="_toggle_7a3252" id="model-team-smart-picking-toggle" data-testid="settings-model-team-smart-picking-toggle" type="checkbox" checked=""></label></div><p class="_poolCount_20c7dc" data-testid="settings-model-team-routing-count">Smart picking pool: 1 model</p><div class="_notices_20c7dc"><div role="note" data-has-title="false" data-action-count="1" data-testid="settings-model-team-no-effect-notice" class="_notice_14d7f7 _toneWarning_14d7f7 _placementInline_14d7f7 _densityCompact_14d7f7"><span class="_icon_14d7f7" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg></span><div class="_body_14d7f7"><div class="_description_14d7f7">Smart picking is on, but Rebel needs at least one extra model to pick between.</div></div><div class="_actions_14d7f7"><button class="btn-shimmer inline-flex items-center justify-center whitespace-nowrap font-medium cursor-pointer transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opac