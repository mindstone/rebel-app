// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SubscriptionSection > matches snapshot for canceled banner copy and managed allowance restart hint 1`] = `"<div data-section="subscription" data-testid="settings-subscription-section"><div class="_subscriptionBanner_d5ce51 _subscriptionBannerInfo_d5ce51" data-testid="settings-subscription-canceled-banner"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-info" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg><div class="_subscriptionBannerBody_d5ce51"><p>Your subscription has ended. Re-subscribe whenever you're ready — your settings are still here.</p><p class="_subscriptionRoutingHint_d5ce51">Once you re-subscribe, your Mindstone allowance will pick back up automatically.</p><div class="_subscriptionBannerActions_d5ce51"><button class="btn-shimmer inline-flex items-center justify-center whitespace-nowrap font-medium cursor-pointer transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 btn-shimmer-subtle btn-outline border border-[color:color-mix(in_srgb,var(--color-border)_78%,transparent)] bg-[color:color-mix(in_srgb,var(--color-background)_94%,transparent)] text-[color:var(--color-muted-foreground)] hover:bg-[rgba(139,92,246,0.10)] hover:text-foreground hover:border-[rgba(139,92,246,0.30)] h-8 [border-radius:8px] gap-1.5 px-3 text-xs [&amp;_svg]:size-3.5" data-testid="settings-subscription-resubscribe-dash">Re-subscribe (Dash)</button><button class="btn-shimmer inline-flex items-center justify-center whitespace-nowrap font-medium cursor-pointer transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 btn-shimmer-subtle btn-outline border border-[color:color-mix(in_srgb,var(--color-border)_78%,transparent)] bg-[color:color-mix(in_srgb,var(--color-background)_94%,transparent)] text-[color:var(--color-muted-foreground)] hover:bg-[rgba(139,92,246,0.10)] hover:text-foreground hover:border-[rgba(139,92,246,0.30)] h-8 [border-radius:8px] gap-1.5 px-3 text-xs [&amp;_svg]:size-3.5" data-testid="settings-subscription-resubscribe-rogue">Re-subscribe (Rogue)</button></div></div></div></div>"`;

exports[`SubscriptionSection > matches snapshot for current-plan cancellation hint when cancelAtPeriodEnd is true 1`] = `"<div data-section="subscription" data-testid="settings-subscription-section"><div class="_subscriptionCurrentPlan_d5ce51" data-testid="settings-subscription-current-plan"><div class="_subscriptionCurrentPlanHeader_d5ce51"><h4 class="_subscriptionCurrentPlanTitle_d5ce51">Dash</h4><span class="_subscriptionActiveBadge_d5ce51">Subscription active</span></div><p class="_subscriptionCurrentPlanMeta_d5ce51">Cancels on 30 June 2026</p><p class="_subscriptionCurrentPlanMeta_d5ce51" data-testid="settings-subscription-cancel-hint">You'll keep full access until then.</p><div class="_subscriptionActions_d5ce51"><button class="btn-shimmer inline-flex items-center justify-center whitespace-nowrap font-medium cursor-pointer transition-all duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 btn-shimmer-subtle btn-outline border border-[color:color-mix(in_srgb,var(--color-border)_78%,transparent)] bg-[color:color-mix(in_srgb,var(--color-background)_94%,transparent)] text-[color:var(--color-muted-foreground)] hover:bg-[rgba(139,92,246,0.10)] hover:text-foreground hover:border-[rgba(139,92,246,0.30)] h-8 [border-radius:8px] gap-1.5 px-3 text-xs [&amp;_svg]:size-3.5" data-testid="settings-subscription-manage-button">Manage subscription</button></div></div></div>"`;
